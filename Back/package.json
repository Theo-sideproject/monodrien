{
  "name": "monopoly-backend",
  "version": "1.0.0",
  "description": "Backend API pour le jeu Monopoly multijoueur",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --verbose",
    "test:auth": "jest --testPathPattern=\"(auth|user)\" --verbose",
    "test:auth:watch": "jest --testPathPattern=\"(auth|user)\" --watch",
    "test:game": "jest --testPathPattern=\"game\" --verbose",
    "test:integration": "jest --testPathPattern=\"integration\" --verbose",
    "test:security": "jest --testPathPattern=\"security\" --verbose",
    "test:unit": "jest --testPathPattern=\"test\\.js$\" --verbose",
    "test:performance": "jest --testPathPattern=\"performance\" --verbose --runInBand",
    "test:all": "npm run test:auth && npm run test:game && npm run test:integration && npm run test:security && npm run test:performance",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:setup": "node setup-test-env.js",
    "test:full": "node run-all-tests.js",
    "test:verify": "node test-fix-verification.js",
    "test:security-fixes": "node test-security-fixes.js",
    "test:report": "npm run test:coverage && echo '\\n=== RAPPORT DE SYNTHÈSE ===' && npm run test:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "node-fetch": "^2.7.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.8"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/data/**",
      "!**/*.config.js"
    ],
    "coverageReporters": ["text", "lcov", "html", "json"],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "src/models/": {
        "branches": 85,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "src/middleware/": {
        "branches": 85,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "src/routes/auth.js": {
        "branches": 90,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "verbose": true,
    "detectOpenHandles": true,
    "forceExit": true
  },
  "keywords": ["monopoly", "multiplayer", "game", "lobby", "websocket"],
  "author": "MonoDrien Team",
  "license": "MIT"
}
